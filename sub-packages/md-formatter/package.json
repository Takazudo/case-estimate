{
  "name": "@takazudo/md-formatter",
  "version": "1.0.0",
  "description": "AST-based markdown and MDX formatter with Japanese text support",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "md-formatter": "./src/cli.js"
  },
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "format": "node src/cli.js --write \"**/*.{md,mdx}\"",
    "format:check": "node src/cli.js --check \"**/*.{md,mdx}\"",
    "prepare": "husky"
  },
  "keywords": [
    "markdown",
    "mdx",
    "formatter",
    "remark",
    "unified",
    "japanese"
  ],
  "author": "Takazudo",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "glob": "^10.5.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.7.4",
    "remark": "^15.0.1",
    "remark-directive": "^3.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.15",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
