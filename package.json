{
  "name": "takazudo-modular-panels",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "next dev --port 3200",
    "dev2": "next dev --port 3201",
    "build": "next build",
    "build:with-docs": "pnpm run build && (cd doc && pnpm run build) && mkdir -p out && cp -r doc/build out/doc || (echo 'Build failed' && exit 1)",
    "start": "next start",
    "doc:dev": "cd doc && pnpm run start",
    "doc:build": "cd doc && pnpm run build",
    "doc:serve": "cd doc && pnpm run serve",
    "doc:clear": "cd doc && pnpm run clear",
    "lint": "eslint app components hooks utils data types --ext .ts,.tsx",
    "lint:fix": "eslint app components hooks utils data types --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css}\" \"!**/*.{md,mdx}\" \"!node_modules/**\" \"!.next/**\" \"!out/**\" \"!public/**\" \"!__inbox/**\" \"!doc/**\" \"!worktrees/**\" \"!sub-packages/**\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css}\" \"!**/*.{md,mdx}\" \"!node_modules/**\" \"!.next/**\" \"!out/**\" \"!public/**\" \"!__inbox/**\" \"!doc/**\" \"!worktrees/**\" \"!sub-packages/**\"",
    "format:md": "node sub-packages/md-formatter/src/cli.js --check \"**/*.{md,mdx}\"",
    "format:md:fix": "node sub-packages/md-formatter/src/cli.js --write \"**/*.{md,mdx}\"",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format && pnpm run format:md",
    "check:fix": "pnpm run lint:fix && pnpm run format:fix && pnpm run format:md:fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "playwright test tests/e2e.spec.ts",
    "test:smoke:production": "playwright test tests/e2e.spec.ts --config playwright.config.production.ts",
    "test:e2e": "playwright test tests/e2e.spec.ts",
    "test:e2e:production": "playwright test --config playwright.config.production.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "b4push": "./scripts/b4push-quick.sh",
    "b4push:full": "./scripts/b4push.sh",
    "b4push:quick": "./scripts/b4push-quick.sh",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@headlessui/react": "^2.2.7",
    "@heroicons/react": "^2.2.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^15.5.3",
    "@next/third-parties": "^15.5.3",
    "blurhash": "^2.0.5",
    "next": "^15.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.4.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.1.6",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "puppeteer": "^24.23.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,yml,yaml}": [
      "prettier --write"
    ],
    "*.{md,mdx}": [
      "node sub-packages/md-formatter/src/cli.js --write"
    ]
  }
}
